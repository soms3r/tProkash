{
  "name": "@tprokash/database",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean --dts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "del-cli dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit generate --check",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {
    "@tprokash/config": "workspace:*",
    "@tprokash/types": "workspace:*",
    "drizzle-orm": "^0.40.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@tprokash/eslint-config": "workspace:*",
    "@tprokash/tsconfig": "workspace:*",
    "@types/node": "^22.20.0",
    "drizzle-kit": "^0.30.6",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.7"
  }
}
