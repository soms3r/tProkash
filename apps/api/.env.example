# ── API Server ──

# Port the API server listens on
PORT=4000

# Node environment: development | production | test
NODE_ENV=development

# API prefix (e.g. "api/v1")
API_PREFIX=api/v1

# Log level: debug | info | warn | error
LOG_LEVEL=info

# CORS allowed origin (comma-separated or "*")
CORS_ORIGIN=*

# Database connection string (PostgreSQL)
# Leave empty to run without database (health will show disconnected)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tprokash
